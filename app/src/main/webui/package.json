{
  "name": "homelab-manager",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "orval --config ./orval.config.ts && vite",
    "build": "orval --config ./orval.config.ts && vue-tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "vue-tsc -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ci": "eslint . && vitest run",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@tanstack/vue-query": "^5.101.2",
    "axios": "^1.9.0",
    "chart.js": "^4.5.1",
    "pinia": "^3.0.4",
    "rxjs": "^7.8.2",
    "vue": "^3.5.13",
    "vue-chartjs": "^5.3.4",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@vitejs/plugin-vue": "^5.2.2",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.9.0",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.0",
    "eslint": "^10.7.0",
    "eslint-plugin-vue": "^10.9.2",
    "jsdom": "^29.1.1",
    "orval": "^7.8.0",
    "prettier": "^3.5.3",
    "tailwindcss": "^4.3.2",
    "typescript": "~5.8.0",
    "vite": "^6.3.1",
    "vitest": "^4.1.10",
    "vue-tsc": "^2.2.8"
  }
}
